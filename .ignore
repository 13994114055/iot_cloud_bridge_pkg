# ============================================================
# 编译产物（ROS2 / Colcon / CMake）
# ============================================================
build/
install/
log/
.DS_Store

# ============================================================
# 开发工具（IDE / 编辑器配置）
# ============================================================
.vscode/
.idea/
*.code-workspace

# ============================================================
# Python 缓存（Launch 文件涉及 Python）
# ============================================================
__pycache__/
*.pyc
*.pyo

# ============================================================
# 临时文件
# ============================================================
*~
*.swp
*.tmp

# ============================================================
# 配置文件（敏感信息，不要上传到公开仓库）
# ============================================================
config/l610_config.yaml
*.secret.yaml

# ============================================================
# 其他可能的敏感或临时文件
# ============================================================
*.log
*.out
core.*